  "componentSrcMap": {
    "Modal": "src/features/shared/ui/Modal.tsx",
    "Tooltip": "src/features/shared/ui/Tooltip.tsx",
    "PageLoader": "src/features/shared/ui/PageLoader.tsx",
    "UserAvatar": "src/features/shared/auth/components/UserAvatar.tsx",
    "LoginForm": "src/features/shared/auth/components/LoginForm.tsx",
    "AxeousLogo": "src/components/ui/AxeousLogo.tsx",
    "Navbar": "src/features/shared/navigation/Navbar.tsx",
    "RoadmapTrack": "src/features/learn/roadmap/RoadmapTrack.tsx",
    "SessionHud": "src/features/learn/tests/components/SessionHud.tsx",
    "QuestionTimer": "src/features/learn/tests/components/QuestionTimer.tsx",
    "AnswerSurface": "src/features/learn/tests/components/AnswerSurface.tsx",
    "FeedbackPanel": "src/features/learn/tests/components/FeedbackPanel.tsx",
    "SessionComplete": "src/features/learn/tests/components/SessionComplete.tsx",
    "AiTutorPanel": "src/features/learn/tests/components/AiTutorPanel.tsx",
    "SessionReview": "src/features/learn/tests/components/SessionReview.tsx",
    "PracticeSession": "src/features/learn/tests/components/PracticeSession.tsx",
    "FlashcardGenerator": "src/features/learn/flashcards/components/FlashcardGenerator.tsx",
    "AbgDriller": "src/features/learn/abg/components/AbgDriller.tsx",
    "CollectNavbar": "src/features/collect/navigation/CollectNavbar.tsx",
    "MultiView": "src/features/collect/dashboard/MultiView.tsx",
    "TelegramRow": "src/features/collect/telegram/components/TelegramRow.tsx",
    "AdvancedModeRow": "src/features/collect/advanced/components/AdvancedModeRow.tsx",
    "ItemMenu": "src/features/collect/purchases/components/ItemMenu.tsx",
    "WatchFeed": "src/features/collect/watches/components/WatchFeed.tsx",
    "ResultCard": "src/features/collect/ebay/components/ResultCard.tsx",
    "FilterPanel": "src/features/collect/ebay/components/FilterPanel.tsx",
    "AspectSelect": "src/features/collect/ebay/components/AspectSelect.tsx"
  }
