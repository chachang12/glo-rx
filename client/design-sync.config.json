{
  "pkg": "glo-practice-tester",
  "globalName": "Axeous",
  "projectId": "310c625a-527d-42e5-a577-275a943a961b",
  "shape": "package",
  "srcDir": "src",
  "tsconfig": "tsconfig.json",
  "entry": ".design-sync/dist-lib/ds-entry.js",
  "cssEntry": ".design-sync/styles/axeous-bundle.css",
  "runtimeFontPrefixes": ["Geist", "JetBrains Mono"],
  "overrides": {
    "Modal": { "cardMode": "single", "viewport": "560x440" }
