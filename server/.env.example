ANTHROPIC_API_KEY=sk-ant-...

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/axeous

BETTER_AUTH_SECRET=generate-a-long-random-string-here

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# ── eBay Browse API (Axeous Collect) ─────────────────────────────────────────
# Create an application keyset at https://developer.ebay.com/ and join the
# eBay Partner Network for affiliate links: https://partnernetwork.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_EPN_CAMPAIGN_ID=          # 10-digit campaign ID, required for affiliate URLs
EBAY_EPN_REFERENCE_ID=axeous-collect
EBAY_USER_COUNTRY=US
EBAY_USER_ZIP=37402
EBAY_API_BASE=https://api.ebay.com
WATCH_POLL_INTERVAL_MS=60000
WATCH_MAX_CONCURRENT=3

# ── eBay marketplace account-deletion notifications (already configured) ─────
EBAY_VERIFICATION_TOKEN=
EBAY_DELETION_ENDPOINT_URL=https://api.axeous.com/api/ebay-deletion
